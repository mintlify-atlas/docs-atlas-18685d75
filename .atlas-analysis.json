  "keyFeatures": [
    "Course and campaign management for Wikipedia education programs",
    "Wikipedia OAuth authentication and user role management (instructor, student, admin)",
    "Automated analytics pipeline tracking article edits, views, and quality scores",
    "Training module system with content from wiki pages",
    "Multi-wiki support across Wikimedia projects (Wikipedia, Wikidata, Wikimedia Commons)",
    "Assignment wizard for structured course timeline creation",
    "Plagiarism detection integration via CopyPatrol",
    "Article quality scoring via Lift Wing API",
    "Internationalization support via translatewiki.net",
    "Survey system for gathering program feedback"
  ],
  "publicApiSurface": [
    "GET /courses/:slug/course.json",
